{
  "name": "speedycat-proxy-functions",
  "description": "SpeedyCAT AI answer-checker cloud proxy (OpenAI via Firebase Secret Manager)",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions:checkSpeedycatAnswer"
  },
  "dependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
