<?xml version="1.0" encoding="utf-8"?>
<!-- Small cheetah "m" mark + "SpeedyCAT" wordmark, side by side. logo_star_144dp is
     used (rather than the transparent launcher foreground) because it carries its own
     background, so the mark stays legible on light, dark and black drawer themes. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp">

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/logo_star_144dp"
        android:scaleType="fitCenter"
        android:contentDescription="@string/app_name" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/app_name"
        android:textColor="?attr/navDrawerItemColor"
        android:textSize="20sp"
        android:textStyle="bold" />
</LinearLayout>
