<?xml version="1.0" encoding="utf-8"?>
<!-- SpeedyCAT: General — language and video driver only (desktop parity). -->
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:title="@string/pref_cat_general"
    android:key="@string/pref_general_screen_key">
    <ListPreference
        android:defaultValue="@string/empty_string"
        android:key="@string/pref_language_key"
        android:icon="@drawable/ic_language_black_24dp"
        android:title="@string/language"
        app:useSimpleSummaryProvider="true"/>
    <ListPreference
        android:defaultValue="hardware"
        android:entries="@array/video_driver_labels"
        android:entryValues="@array/video_driver_values"
        android:key="@string/pref_video_driver_key"
        android:title="@string/pref_video_driver_title"
        android:summary="@string/pref_video_driver_summary"
        app:useSimpleSummaryProvider="true"/>
</PreferenceScreen>
