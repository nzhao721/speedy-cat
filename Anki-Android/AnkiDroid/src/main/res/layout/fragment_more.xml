<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:statusBarForeground="?attr/appBarColor"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/bottom_nav_more"
            app:titleTextAppearance="?attr/textAppearanceTitleLarge" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- SpeedyCAT: signed-in account identity (email/username, or "Not signed in").
                 Tapping opens the account screen. -->
            <LinearLayout
                android:id="@+id/more_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="64dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_people_black_24dp"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.ichi2.ui.FixedTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/speedycat_account"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.ichi2.ui.FixedTextView
                        android:id="@+id/more_account_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/speedycat_not_signed_in"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="16dp" />

            <!-- SpeedyCAT: Practice Questions -->
            <LinearLayout
                android:id="@+id/more_practice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_round_assignment_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/speedycat_practice_questions"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <!-- SpeedyCAT: Readiness (Memory / Performance metric) -->
            <LinearLayout
                android:id="@+id/more_readiness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_bar_chart_black"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/speedycat_readiness"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="16dp" />

            <!-- Settings -->
            <LinearLayout
                android:id="@+id/more_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_settings_black"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="16dp" />

            <!-- Privacy policy (kept accessible; Help and Support sections were removed) -->
            <LinearLayout
                android:id="@+id/more_help_privacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ic_baseline_privacy_tip_24"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <com.ichi2.ui.FixedTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_title_privacy"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
